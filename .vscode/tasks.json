// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "watch:esbuild",
            "type": "npm",
            "script": "watch",
            "problemMatcher": "$esbuild-watch",
            "isBackground": true,
            "presentation": {
                "group": "watch",
                "reveal": "never"
            }
        },
        {
            "label": "watch:tsc",
            "type": "shell",
            "command": "npx tsc -p ./ --watch",
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "presentation": {
                "group": "watch",
                "reveal": "never"
            }
        },
        {
            "label": "watch",
            "dependsOn": [
                "watch:esbuild",
                "watch:tsc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
